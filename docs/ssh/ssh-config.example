# ROAD A EYE — 4개 서버 SSH config 예시
# 사용법: <...> 부분을 실제 값으로 채워 ~/.ssh/config 에 추가하세요.
# ⚠️ 실제 IP·계정·개인키는 저장소에 포함하지 않습니다. 팀 내부 채널로만 공유하세요.

Host ai
    HostName <AI_SERVER_IP>      # AI 서버 (FastAPI :8001, YOLO/Keras)
    User <AI_USER>
    IdentityFile ~/.ssh/id_ed25519
    StrictHostKeyChecking no

Host back
    HostName <BACK_SERVER_IP>    # Back-end (FastAPI :8000, JWT)
    User <BACK_USER>
    IdentityFile ~/.ssh/id_ed25519
    StrictHostKeyChecking no

Host front
    HostName <FRONT_SERVER_IP>   # Front-end (Next.js :3000)
    User <FRONT_USER>
    IdentityFile ~/.ssh/id_ed25519
    StrictHostKeyChecking no

Host db
    HostName <DB_SERVER_IP>      # DB 백업 (MySQL Replica)
    User <DB_USER>
    IdentityFile ~/.ssh/id_ed25519
    StrictHostKeyChecking no
